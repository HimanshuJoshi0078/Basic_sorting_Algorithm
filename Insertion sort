#include<iostream>
using namespace std;
//Insertion sort:O(n^2)
int main(){
    int arr[5] = {55,46,33,21,17};
    int n=5;
    for(int i=0;i<n;i++){
        for(int j=0;j<n-1;j++){
            if(arr[j]>arr[j+1]){
                swap(arr[j],arr[j+1]);
            }
        }
    }
    
    //display sorted array
    for(int i=0;i<n;i++){
        cout<<arr[i]<<" ";
    }
}
